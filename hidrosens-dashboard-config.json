 textoBruto = JSON.stringify(value);\n    } else {\n        textoBruto = String(value);\n    }\n} catch (e) {\n    return null; // Se der erro, ignora o ponto\n}\n\n// 2. Busca o número após \"Distance\"\nvar regex = /Distance[^\\d]*([\\d\\.]+)/i;\nvar match = textoBruto.match(regex);\n\nif (match && match[1]) {\n    var leitura = parseFloat(match[1]);\n\n    // Filtro de segurança: Se a leitura for absurda (ex: negativa ou maior que o tanque), ignora\n    // Você pode remover esse IF se quiser aceitar qualquer valor\n    if (leitura < 0 || (CALCULAR_NIVEL && leitura > ALTURA_TANQUE + 1)) {\n         return null; \n    }\n\n    if (CALCULAR_NIVEL) {\n        var nivel = ALTURA_TANQUE - leitura;\n        return Number(Math.max(0, nivel).toFixed(2));\n        //return 0;\n    }\n\n    return Number(leitura.toFixed(2));\n}\n\n// 3. SE NÃO ACHAR \"DISTANCE\", RETORNA NULL\n// Isso faz o gráfico ignorar essa mensagem (RSSI, Status, etc) em vez de plotar 0.\nreturn prevValue;"}],"alarmFilterConfig":{"statusList":["ACTIVE"]},"latestDataKeys":[]}],"timewindow":{"hideAggregation":false,"hideAggInterval":false,"hideTimezone":false,"selectedTab":0,"realtime":{"realtimeType":0,"interval":60000,"timewindowMs":7200000,"quickInterval":"CURRENT_DAY","hideInterval":false,"hideLastInterval":false,"hideQuickInterval":false},"history":{"historyType":0,"interval":1000,"timewindowMs":60000,"fixedTimewindow":null,"quickInterval":"CURRENT_DAY","hideInterval":false,"hideLastInterval":false,"hideFixedInterval":false,"hideQuickInterval":false},"aggregation":{"type":"NONE","limit":25000},"timezone":null},"showTitle":true,"backgroundColor":"rgba(0, 0, 0, 0)","color":"rgba(0, 0, 0, 0.87)","padding":"0px","settings":{"comparisonEnabled":false,"timeForComparison":"previousInterval","comparisonCustomIntervalValue":7200000,"comparisonXAxis":{"show":true,"label":"","labelFont":{"family":"Roboto","size":12,"sizeUnit":"px","style":"normal","weight":"600","lineHeight":"1"},"labelColor":"rgba(0, 0, 0, 0.