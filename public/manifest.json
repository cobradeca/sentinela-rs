{
  "name": "Sentinela RS",
  "short_name": "Sentinela",
  "id": "/sentinela-rs/",
  "description": "Sistema de monitoramento de catástrofes e eventos extremos — Rio Grande do Sul.",
  "start_url": "/sentinela-rs/",
  "scope": "/sentinela-rs/",
  "display": "standalone",
  "background_color": "#070b12",
  "theme_color": "#070b12",
  "orientation": "portrait",
  "lang": "pt-BR",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=io.cobradeca.sentinela_rs"
    }
  ],
  "iarc_rating_id": "e84b5d40-17a3-49b6-9545-c7687aa7a72e",
  "categories": [
    "utilities",
    "weather",
    "news"
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Abrir dashboard principal",
      "url": "/sentinela-rs/?tab=dashboard",
      "icons": [
        {
          "src": "/sentinela-rs/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/sentinela-rs/screenshots/mobile-dashboard.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "/sentinela-rs/screenshots/desktop-dashboard.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],
  "launch_handler": {
    "client_mode": ["navigate-new"]
  },
  "scope_extensions": [
    {
      "origin": "https://cobradeca.github.io"
    }
  ],
  "background_sync": {
    "sync_events": [
      "sync-alertas",
      "sync-dados"
    ]
  },
  "share_target": {
    "action": "/sentinela-rs/share",
    "method": "POST",
    "enctype": "application/json",
    "params": {
      "title": "titulo",
      "text": "descricao",
      "url": "url"
    }
  },
  "periodic_background_sync": {
    "min_interval": 3600000,
    "tag": "update-alertas"
  },
  "protocol_handlers": [
    {
      "protocol": "mailto",
      "url": "/sentinela-rs/?mailto=%s"
    }
  ],
  "widgets": [
    {
      "name": "Alertas Sentinela",
      "short_name": "Alertas",
      "description": "Widget de alertas em tempo real",
      "tag": "widget-alertas",
      "screenshot": {
        "src": "/sentinela-rs/icons/icon-192.png",
        "sizes": "192x192"
      },
      "data": {
        "refresh_interval": 600000
      }
    }
  ],
  "window_controls_overlay": {
    "title_bar_color": "#070b12",
    "icon_color": "#ffffff"
  },
  "push_notifications": {
    "icon": "/sentinela-rs/icons/icon-192.png",
    "badge": "/sentinela-rs/icons/icon-192.png",
    "tag": "sentinela-alert"
  },
  "icons": [
    {
      "src": "/sentinela-rs/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/sentinela-rs/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/sentinela-rs/icons/maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/sentinela-rs/icons/maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
