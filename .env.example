# Supabase — pegue em: app.supabase.com → seu projeto → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# VAPID Key pública — gerada com: npx web-push generate-vapid-keys
# A chave privada fica SOMENTE nas variáveis de ambiente do Supabase (nunca no frontend)
VITE_VAPID_PUBLIC_KEY=sua_vapid_public_key_aqui
